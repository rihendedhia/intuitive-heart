---
// Curated grid items mimicking an active Instagram footprint
// without relying on heavy client-side JavaScript APIs.
const galleryItems = [
  {
    src: '/gallery/image-1.jpeg',
    alt: 'Tarot cards laid out under soft moonlight with crystals',
    caption: 'Aligning with the cosmic energy of the New Moon',
    link: 'https://www.instagram.com/p/DXrYwlfAhPh/?img_index=1&igsh=aHdlc3J1c3BoOHZm',
    orientation: 'vertical',
  },
  {
    src: '/gallery/image-2.jpeg',
    alt: 'A warm room setup with a journal, tea, and oracle cards',
    caption: 'Safe spaces for deep transformation and inner work',
    link: 'https://www.instagram.com/reel/DYhdkMbMzoA/?igsh=YzhuNDZuMmVtMHJw',
    orientation: 'vertical',
  },
  {
    src: '/gallery/image-3.jpeg',
    alt: 'Candles and crystals arranged on a wooden altar',
    caption: 'A quiet ritual for slowing down and sensing what truly matters',
    link: 'https://www.instagram.com/intuitiveheart/',
    orientation: 'vertical',
  },
  {
    src: '/gallery/image-4.jpeg',
    alt: 'A horizontal view of a serene space with tarot cards and journaling',
    caption: 'A wider perspective on the soulful tools that support your practice',
    link: 'https://www.instagram.com/intuitiveheart/',
    orientation: 'horizontal',
  },
];
---

<section class="ih-section ih-gallery-section" id="gallery" aria-labelledby="gallery-title">
  <div class="ih-container">
    <div class="ih-fade">
      <p class="ih-label">Digital Sanctuary</p>
      <h2 class="ih-title">Follow the <em>Journey</em></h2>
      <p class="ih-body" style="max-width:600px;">
        A glimpse into the daily rituals, spiritual tools, and cosmic insights shared on social
        spaces.
      </p>
    </div>

    <div class="ih-gallery-grid">
      {
        galleryItems.map((item) => (
          <a
            href={item.link}
            target="_blank"
            rel="noopener noreferrer"
            class={`ih-gallery-card ih-fade ${item.orientation}`}
            aria-label={item.alt}
          >
            <div class={`ih-image-wrapper ${item.orientation}`}>
              <img src={item.src} alt={item.alt} loading="lazy" class="ih-gallery-img" />
              <div class="ih-gallery-overlay">
                <div class="ih-overlay-content">
                  <span class="ih-instagram-icon">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="24"
                      height="24"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
                      <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                      <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
                    </svg>
                  </span>
                  <p class="ih-overlay-caption">{item.caption}</p>
                </div>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .ih-gallery-section {
    background: var(--teal-light);
  }

  .ih-gallery-grid {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: 1.75rem;
    margin-top: 3rem;
  }

  @media (min-width: 720px) {
    .ih-gallery-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1100px) {
    .ih-gallery-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .ih-gallery-card {
    display: block;
    text-decoration: none;
    outline: none;
  }

  .ih-gallery-card.horizontal {
    grid-column: span 2;
  }

  @media (max-width: 1100px) {
    .ih-gallery-card.horizontal {
      grid-column: span 1;
    }
  }

  .ih-image-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: var(--radius);
    border: 1px solid rgba(155, 142, 196, 0.18);
    box-shadow: 0 12px 36px rgba(26, 22, 37, 0.08);
    transition:
      transform 0.35s ease,
      border-color 0.35s ease,
      box-shadow 0.35s ease;
    min-height: 320px;
  }

  .ih-image-wrapper.vertical {
    aspect-ratio: 4 / 5;
  }

  .ih-image-wrapper.horizontal {
    aspect-ratio: 16 / 9;
  }

  .ih-gallery-img,
  .ih-gallery-overlay {
    border-radius: inherit;
  }

  .ih-gallery-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .ih-gallery-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.04) 0%, rgba(38, 30, 54, 0.9) 100%);
    opacity: 0;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 1.25rem;
    transition: opacity 0.35s ease;
  }

  .ih-overlay-content {
    width: 100%;
    text-align: left;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.65rem;
    transform: translateY(15px);
    transition: transform 0.45s ease;
  }

  .ih-instagram-icon {
    color: var(--gold);
    opacity: 0.95;
  }

  .ih-overlay-caption {
    color: var(--white);
    font-size: 0.95rem;
    line-height: 1.65;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-family: inherit;
  }

  .ih-image-wrapper:hover {
    transform: translateY(-4px);
    border-color: rgba(201, 168, 76, 0.35);
    box-shadow: 0 18px 46px rgba(26, 22, 37, 0.12);
  }

  .ih-image-wrapper:hover .ih-gallery-img {
    transform: scale(1.08);
  }

  .ih-image-wrapper:hover .ih-gallery-overlay {
    opacity: 1;
  }

  .ih-image-wrapper:hover .ih-overlay-content {
    transform: translateY(0);
  }

  @media (max-width: 720px) {
    .ih-gallery-section {
      padding-top: 4rem;
      padding-bottom: 4rem;
    }
  }
</style>
