---
import Layout from '../../components/Layout.astro';

export async function getStaticPaths() {
  return Object.entries(import.meta.glob('../../content/blog/*.md', { eager: true })).map(
    ([path]) => ({
      params: {
        slug: path.split('/').pop().replace(/\.md$/, ''),
      },
    })
  );
}

const posts = Object.entries(import.meta.glob('../../content/blog/*.md', { eager: true })).map(
  ([path, module]) => ({
    slug: path.split('/').pop().replace(/\.md$/, ''),
    ...module,
  })
);

const post = posts.find((item) => item.slug === Astro.params.slug);
if (!post) {
  throw new Error('Post not found');
}
const Content = post.default;
---

<Layout title={post.frontmatter.title}>
  <section class="ih-article">
    <header class="ih-article-header">
      <p class="ih-label">{post.frontmatter.category}</p>
      <h1 class="ih-title">{post.frontmatter.title}</h1>
      <div class="ih-article-meta">
        <span>{post.frontmatter.author}</span>
        <span
          >{
            new Date(post.frontmatter.pubDate).toLocaleDateString('en-IN', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })
          }</span
        >
      </div>
    </header>
    <div class="ih-article-body">
      <Content />
    </div>
  </section>
</Layout>
